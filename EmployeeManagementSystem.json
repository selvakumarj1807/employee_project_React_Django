        "url": {
          "raw": "http://127.0.0.1:8000/api/employees/",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "employees", ""]
        }
      }
    },
    {
      "name": "Search Employees",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer <access_token_here>" }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/employees/?search=John",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "employees", ""],
          "query": [
            { "key": "search", "value": "John" }
          ]
        }
      }
    },

        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer <access_token_here>" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Employee Basic Form\",\n  \"fields\": [\n    {\"label\": \"First Name\", \"field_type\": \"text\"},\n    {\"label\": \"Age\", \"field_type\": \"number\"},\n    {\"label\": \"Date of Joining\", \"field_type\": \"date\"}\n  ]\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/forms/",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "forms", ""]
        }
      }
    },
    {
      "name": "List Forms",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer <access_token_here>" }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/forms/",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "forms", ""]
        }
      }
    },
